KRUD_API_HOST=127.0.0.1
KRUD_API_PORT=8000
KRUD_PUBLIC_BASE_URL=http://127.0.0.1:8000
# Browser URL used in `krud login` approval links. This host must route
# /cli-auth and /device to the backend.
KRUD_DEVICE_BASE_URL=http://127.0.0.1:8000
KRUD_DOWNLOAD_BASE_URL=http://127.0.0.1:9000
KRUD_RELEASE_VERSION=0.1.0
# Production database:
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Local development and tests:
KRUD_DATABASE_PATH=krud.db
KRUD_BILLING_MODE=mock
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_PRODUCT_ID=
DODO_PAYMENTS_ENVIRONMENT=test_mode
KRUD_TRIAL_DAYS=14
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=45
KRUD_BILLING_SUCCESS_URL=http://127.0.0.1:8000/billing/success
KRUD_BILLING_CANCEL_URL=http://127.0.0.1:8000/billing/cancel
KRUD_BILLING_PORTAL_RETURN_URL=http://127.0.0.1:8000/billing
